# ==========================================
# Doktainer — Environment Variables
# ==========================================

/* -------------------------------- Runtime -------------------------------- */
# Frontend runtime
NEXT_PUBLIC_PANEL_NAME=DOKTAINER
NEXT_PUBLIC_VERSION=v0.1.2
NEXT_PUBLIC_BATCH=Batch-20260616

# For Docker deployment, leave NEXT_PUBLIC_API_URL unset so the
# browser uses same-origin /api/v1 and Next proxies it to the backend.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000


/* --------------- Connection settings for PostgreSQL database -------------- */
# Frontend server
FRONTEND_URL=http://localhost:3000

# Optional canonical/backend URL if ever needed
BACKEND_URL=http://127.0.0.1:4000

# Backend listen address
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://doktainer:doktainerdb@localhost:5432/doktainer?schema=public"

# JWT settings
JWT_SECRET=dev-super-secret-jwt-key-change-in-production-32chars
JWT_EXPIRES_IN=7d


/* -------------------------- Reverse proxy / rate limiting ------------------------- */
TRUST_PROXY=false
RATE_LIMIT_MAX=300
RATE_LIMIT_TIME_WINDOW=1 minute

# Optional comma-separated extra frontend origins for direct backend access.
# CORS_ORIGINS=http://localhost:3000,https://panel.example.com

# Optional internal backend URL.
# INTERNAL_API_URL=http://127.0.0.1:4000

# Encryption key for SSH private keys (AES-256)
ENCRYPTION_KEY=dev-32-char-encryption-key-here!

/* -------------------------- Optional integrations ------------------------- */
# Optional integrations (deprecated, may be removed in future)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
